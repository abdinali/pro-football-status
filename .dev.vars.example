# Copy this file to `.dev.vars` and fill in real values for local development.
# `.dev.vars` is gitignored; never commit real secrets.
#
# Wrangler reads this file automatically when running `wrangler dev` or
# `next dev` (via the OpenNext dev hook in next.config.ts).

# Supabase → Project Settings → API Keys
# Publishable key → SUPABASE_ANON_KEY | Secret key → SUPABASE_SERVICE_ROLE_KEY
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<publishable-key-or-legacy-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<secret-key-or-legacy-service-role-key>
